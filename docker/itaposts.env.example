# Copia questo file in /etc/itaposts/itaposts.env (o ovunque ITAPOSTS_ENV_FILE
# punti) e compilarlo con le credenziali reali. Permessi attesi: 0600, owner
# coincidente con l'utente che esegue il cron.
#
# I path runtime (SHARED_DATA_DIR, ITAPOSTS_SFTP_LOCAL_DIR, ITAPOSTS_LOCK_DIR)
# sono fissati nel Dockerfile a /var/itaposts/{shared,incoming,run}: non
# vanno aggiunti qui. Lo script host itaposts-sync.sh li bind-monta dal host.

# 1. Credenziali SFTP Lightcast -----------------------------------------------
ITAPOSTS_SFTP_HOST=custom-delivery.lightcast.io
ITAPOSTS_SFTP_PORT=22
ITAPOSTS_SFTP_USER=regionelombardia@lightcast.io
ITAPOSTS_SFTP_PASSWORD=__changeme__
ITAPOSTS_SFTP_REMOTE_DIR=/data_v1/ITC4

# 2. Verifica chiave host SSH (opzionale) -------------------------------------
# Se non valorizzato il container ricade su accept-new alla prima connessione.
# Per pinnare la chiave host, generare /etc/itaposts/known_hosts sul host con:
#   ssh-keyscan -p 22 custom-delivery.lightcast.io | sudo tee /etc/itaposts/known_hosts
# poi aggiungere -v /etc/itaposts/known_hosts:/etc/itaposts/known_hosts:ro al
# docker run (in itaposts-sync.sh) e decommentare:
# ITAPOSTS_SFTP_KNOWN_HOSTS=/etc/itaposts/known_hosts
